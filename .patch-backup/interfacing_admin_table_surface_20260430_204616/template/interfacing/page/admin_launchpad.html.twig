{% extends 'interfacing/base.html.twig' %}
{% block body %}
  {% include 'interfacing/partial/admin_toolbar.html.twig' with {
    eyebrow: 'Admin launchpad',
    title: 'E-commerce operator launchpad',
    description: 'Fast grouped entry point for Smart Responsor CRUD operations, planned component surfaces and route-transparent admin work. Interfacing exposes links and actions; owning components provide fixtures, rows and business data.',
    actions: [
      { label: 'Workspace', url: path('interfacing_index') },
      { label: 'Operations', url: path('interfacing_operation_workbench'), primary: true },
      { label: 'Components', url: path('interfacing_component_roadmap') },
      { label: 'Surface Audit', url: path('interfacing_surface_audit') }
    ]
  } only %}

  {% set opCounts = operationStatusCounts|default({}) %}
  {% set componentCounts = componentRoadmapStatusCounts|default({}) %}
  {% set screenCounts = ecommerceScreenStatusCounts|default({}) %}
  <section style="margin-top:14px; display:grid; grid-template-columns:repeat(6,minmax(0,1fr)); gap:10px;">
    {% for label, value in {
      'Operations': opCounts.total|default(0),
      'Live ops': opCounts.connected|default(0),
      'Canonical ops': opCounts.canonical|default(0),
      'Planned ops': opCounts.planned|default(0),
      'Components': componentCounts.total|default(0),
      'Screen links': screenCounts.total|default(0)
    } %}
      <div style="background:#fff; border:1px solid #dbe1ea; border-radius:14px; padding:11px 12px;">
        <div style="font-size:10px; color:#64748b; text-transform:uppercase; font-weight:800; letter-spacing:.04em;">{{ label }}</div>
        <div style="margin-top:6px; font-size:28px; font-weight:900; letter-spacing:-.03em;">{{ value }}</div>
      </div>
    {% endfor %}
  </section>

  <section style="margin-top:14px; display:grid; grid-template-columns:minmax(0,1.55fr) minmax(330px,.75fr); gap:14px; align-items:start;">
    <div style="display:flex; flex-direction:column; gap:14px;">
      {% for zone, cards in operationGroups|default({}) %}
        <article style="background:#fff; border:1px solid #dbe1ea; border-radius:16px; padding:14px 16px;">
          <div style="display:flex; justify-content:space-between; gap:12px; align-items:flex-start;">
            <div>
              <div style="font-size:11px; color:#2563eb; text-transform:uppercase; font-weight:900; letter-spacing:.05em;">{{ zone }}</div>
              <h2 style="margin:4px 0 0; font-size:22px; letter-spacing:-.02em;">{{ cards|length }} operation card{% if cards|length != 1 %}s{% endif %}</h2>
            </div>
            <a href="{{ path('interfacing_operation_workbench') }}" style="text-decoration:none; border:1px solid #cbd5e1; border-radius:10px; padding:7px 10px; font-size:12px; font-weight:800; color:#0f172a; background:#fff;">Open workbench</a>
          </div>

          <div style="margin-top:12px; display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:10px;">
            {% for card in cards %}
              <div style="border:1px solid #e2e8f0; border-radius:14px; padding:11px 12px; background:#fbfdff; min-width:0;">
                <div style="display:flex; justify-content:space-between; gap:8px; align-items:flex-start;">
                  <div style="min-width:0;">
                    <div style="font-size:10px; color:#64748b; text-transform:uppercase; font-weight:800; letter-spacing:.04em;">{{ card.component }}</div>
                    <div style="margin-top:3px; font-size:15px; font-weight:900; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{{ card.label }}</div>
                  </div>
                  <span style="font-size:10px; border:1px solid #e2e8f0; border-radius:999px; padding:3px 7px; color:{{ card.resourceStatus == 'connected' ? '#047857' : (card.resourceStatus == 'canonical' ? '#2563eb' : '#92400e') }}; background:#fff; white-space:nowrap;">{{ card.resourceStatus }}</span>
                </div>

                <div style="margin-top:10px; display:grid; grid-template-columns:repeat(5,minmax(0,1fr)); gap:5px;">
                  <a href="{{ card.indexUrl }}" style="text-align:center; text-decoration:none; border:1px solid #cbd5e1; border-radius:9px; padding:6px 5px; font-size:11px; font-weight:800; color:#0f172a; background:#fff;">Index</a>
                  <a href="{{ card.newUrl }}" style="text-align:center; text-decoration:none; border:1px solid #cbd5e1; border-radius:9px; padding:6px 5px; font-size:11px; font-weight:800; color:#0f172a; background:#fff;">New</a>
                  <a href="{{ card.showUrl }}" style="text-align:center; text-decoration:none; border:1px solid #cbd5e1; border-radius:9px; padding:6px 5px; font-size:11px; font-weight:800; color:#0f172a; background:#fff;">Show</a>
                  <a href="{{ card.editUrl }}" style="text-align:center; text-decoration:none; border:1px solid #cbd5e1; border-radius:9px; padding:6px 5px; font-size:11px; font-weight:800; color:#0f172a; background:#fff;">Edit</a>
                  <a href="{{ card.deleteUrl }}" style="text-align:center; text-decoration:none; border:1px solid #fecaca; border-radius:9px; padding:6px 5px; font-size:11px; font-weight:800; color:#991b1b; background:#fff;">Delete</a>
                </div>

                <div style="margin-top:8px; font-size:10px; color:#94a3b8; font-family:ui-monospace,SFMono-Regular,Consolas,monospace; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{{ card.indexUrl }}</div>
              </div>
            {% endfor %}
          </div>
        </article>
      {% endfor %}
    </div>

    <aside style="display:flex; flex-direction:column; gap:12px;">
      {% include 'interfacing/partial/operation_status_legend.html.twig' only %}
      {% include 'interfacing/partial/crud_route_grammar.html.twig' only %}
      <section style="background:#fff; border:1px solid #dbe1ea; border-radius:16px; padding:14px 16px;">
        <div style="font-size:11px; color:#2563eb; text-transform:uppercase; font-weight:900; letter-spacing:.05em;">Component obligations</div>
        <div style="margin-top:8px; color:#475569; font-size:12px; line-height:1.45;">Every planned card is intentional: it gives the operator a canonical URL target before the host application connects the owning component. Rows, fixtures and permissions must still come from the owning component.</div>
        <div style="margin-top:10px; display:flex; flex-direction:column; gap:8px;">
          {% for zone, components in componentRoadmapGroups|default({}) %}
            <a href="{{ path('interfacing_component_roadmap') }}#{{ zone|lower|replace({' ':'-', '&':'and'}) }}" style="display:flex; justify-content:space-between; gap:10px; text-decoration:none; color:inherit; border:1px solid #e2e8f0; border-radius:11px; padding:8px 9px; background:#fbfdff;">
              <span style="font-size:12px; font-weight:800;">{{ zone }}</span>
              <span style="font-size:11px; color:#64748b;">{{ components|length }}</span>
            </a>
          {% endfor %}
        </div>
      </section>
    </aside>
  </section>
{% endblock %}
