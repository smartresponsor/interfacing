{% extends 'interfacing/base.html.twig' %}

{% block body %}
  {% set matrixStatus = ecommerceScreenStatusCounts|default({}) %}
  {% set matrixTotal = ecommerceScreenMatrix|default([])|length %}
  <section style="background:#fff; border:1px solid #dbe1ea; border-radius:16px; padding:16px 18px; margin-bottom:14px;">
    <div style="display:flex; justify-content:space-between; gap:12px; align-items:flex-start;">
      <div>
        <div style="font-size:11px; color:#2563eb; text-transform:uppercase; font-weight:700; letter-spacing:.05em;">Screen directory</div>
        <h1 style="margin:6px 0 0; font-size:30px; line-height:1.08; letter-spacing:-.03em;">All known e-commerce screens and CRUD actions</h1>
        <div style="margin-top:8px; color:#475569; max-width:920px; font-size:13px; line-height:1.45;">Shell-native directory generated from screen contracts and the canonical CRUD registry. Connected links should open now; canonical and planned links expose URL patterns without demo rows in Interfacing.</div>
      </div>
      <div style="display:flex; gap:8px; flex-wrap:wrap; justify-content:flex-end;">
        <a href="{{ path('interfacing_index') }}" style="text-decoration:none; padding:9px 12px; border-radius:11px; background:#fff; color:#0f172a; border:1px solid #cbd5e1; font-weight:600; font-size:12px;">Workspace</a>
        <a href="{{ path('interfacing_crud_explorer') }}" style="text-decoration:none; padding:9px 12px; border-radius:11px; background:#2563eb; color:#fff; font-weight:700; font-size:12px;">CRUD Explorer</a>
      </div>
    </div>
  </section>
  <section style="display:grid; grid-template-columns:repeat(4,minmax(0,1fr)); gap:10px; margin-bottom:14px;">
    <article style="background:#fff; border:1px solid #dbe1ea; border-radius:14px; padding:12px 14px;"><div style="font-size:10px; color:#64748b; text-transform:uppercase; font-weight:700;">Total links</div><div style="margin-top:5px; font-size:28px; font-weight:800;">{{ matrixTotal }}</div></article>
    <article style="background:#fff; border:1px solid #dbe1ea; border-radius:14px; padding:12px 14px;"><div style="font-size:10px; color:#64748b; text-transform:uppercase; font-weight:700;">Connected</div><div style="margin-top:5px; font-size:28px; font-weight:800; color:#047857;">{{ matrixStatus.connected|default(0) }}</div></article>
    <article style="background:#fff; border:1px solid #dbe1ea; border-radius:14px; padding:12px 14px;"><div style="font-size:10px; color:#64748b; text-transform:uppercase; font-weight:700;">Canonical</div><div style="margin-top:5px; font-size:28px; font-weight:800; color:#2563eb;">{{ matrixStatus.canonical|default(0) }}</div></article>
    <article style="background:#fff; border:1px solid #dbe1ea; border-radius:14px; padding:12px 14px;"><div style="font-size:10px; color:#64748b; text-transform:uppercase; font-weight:700;">Planned</div><div style="margin-top:5px; font-size:28px; font-weight:800; color:#92400e;">{{ matrixStatus.planned|default(0) }}</div></article>
  </section>
  <section style="display:grid; grid-template-columns:minmax(0, 1fr) 340px; gap:14px; align-items:start;">
    <div style="display:flex; flex-direction:column; gap:14px;">
      {% for zone, entries in ecommerceScreenGroups|default({}) %}
        <article style="background:#fff; border:1px solid #dbe1ea; border-radius:16px; padding:14px 16px;">
          <div style="display:flex; justify-content:space-between; gap:12px; align-items:center; margin-bottom:10px;">
            <div><div style="font-size:11px; color:#2563eb; text-transform:uppercase; font-weight:700; letter-spacing:.05em;">{{ zone }}</div><div style="margin-top:3px; font-size:12px; color:#64748b;">{{ entries|length }} screen/action links</div></div>
            <a href="{{ path('interfacing_crud_explorer') }}" style="text-decoration:none; color:#2563eb; font-size:12px; font-weight:700;">CRUD grammar</a>
          </div>
          <div style="display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:8px;">
            {% for entry in entries %}
              <a href="{{ entry.url }}" style="display:block; text-decoration:none; color:inherit; border:1px solid #edf2f7; border-radius:12px; padding:9px 10px; background:#fbfdff; min-width:0;">
                <div style="display:flex; justify-content:space-between; gap:8px; align-items:flex-start;">
                  <div style="min-width:0;"><div style="font-size:10px; color:#2563eb; text-transform:uppercase; font-weight:700; letter-spacing:.04em;">{{ entry.component }} · {{ entry.operation }}</div><div style="margin-top:4px; font-size:13px; font-weight:800; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{{ entry.label }}</div></div>
                  <span style="font-size:10px; color:{{ entry.status == 'connected' ? '#047857' : (entry.status == 'canonical' ? '#2563eb' : '#92400e') }}; border:1px solid #e2e8f0; border-radius:999px; padding:2px 6px; white-space:nowrap;">{{ entry.status }}</span>
                </div>
                <div style="margin-top:7px; font-size:11px; color:#64748b; font-family:ui-monospace,SFMono-Regular,Consolas,monospace; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{{ entry.url }}</div>
                {% if entry.kind == 'crud-sample' %}<div style="margin-top:5px; font-size:10px; color:#94a3b8;">sample id/slug placeholder</div>{% endif %}
              </a>
            {% endfor %}
          </div>
        </article>
      {% endfor %}
    </div>
    <aside style="display:flex; flex-direction:column; gap:12px;">
      <section style="background:#fff; border:1px solid #dbe1ea; border-radius:16px; padding:14px 16px;">
        <div style="font-size:11px; color:#2563eb; text-transform:uppercase; font-weight:700; letter-spacing:.05em;">Component coverage</div>
        <div style="margin-top:8px; display:flex; flex-direction:column; gap:10px;">
          {% for zone, components in ecommerceComponentGroups|default({}) %}
            <div><div style="font-size:11px; color:#64748b; text-transform:uppercase; font-weight:700;">{{ zone }}</div><div style="margin-top:5px; display:flex; flex-direction:column; gap:5px;">
              {% for component in components %}
                <div style="display:flex; justify-content:space-between; gap:8px; align-items:center; border:1px solid #edf2f7; border-radius:10px; padding:7px 8px;"><div style="font-size:12px; font-weight:700;">{{ component.component }}</div><div style="font-size:11px; color:#64748b;">{{ component.total }} · {{ component.primaryStatus }}</div></div>
              {% endfor %}
            </div></div>
          {% endfor %}
        </div>
      </section>
      <section style="background:#fff; border:1px solid #dbe1ea; border-radius:16px; padding:14px 16px;"><div style="font-size:11px; color:#2563eb; text-transform:uppercase; font-weight:700; letter-spacing:.05em;">Boundary</div><div style="margin-top:8px; font-size:12px; color:#475569; line-height:1.45;">Interfacing owns shell frame, navigation, CRUD URL grammar and rendering states. Business rows, fixtures and real identifiers must come from the owning Smart Responsor components.</div></section>
    </aside>
  </section>
{% endblock %}
