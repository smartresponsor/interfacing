{% extends 'interfacing/base.html.twig' %}

{% block body %}
  {% include 'interfacing/partial/admin_toolbar.html.twig' with {
    eyebrow: 'Component obligations',
    title: 'Owning-component evidence checklist',
    summary: 'Shows what each Smart Responsor component must provide before Interfacing CRUD screens become real runtime screens. Interfacing keeps shell, navigation, route grammar and affordances only.',
    actions: [
      { label: 'Component Roadmap', url: path('interfacing_component_roadmap') },
      { label: 'CRUD Readiness', url: path('interfacing_crud_readiness') },
      { label: 'Admin Tables', url: path('interfacing_admin_tables') },
      { label: 'Launchpad', url: path('interfacing_admin_launchpad') }
    ]
  } only %}

  <section style="display:grid; grid-template-columns:repeat(4,minmax(0,1fr)); gap:12px; margin:0 0 18px;">
    {% for key,label in {'total':'Components','high':'High obligation','medium':'Medium obligation','low':'Low obligation'} %}
      <article style="border:1px solid #e2e8f0; border-radius:16px; padding:14px; background:#fff;">
        <div style="font-size:12px; color:#64748b; font-weight:800; text-transform:uppercase; letter-spacing:.04em;">{{ label }}</div>
        <div style="font-size:28px; font-weight:900; color:#0f172a; margin-top:4px;">{{ componentObligationRiskCounts[key]|default(0) }}</div>
      </article>
    {% endfor %}
  </section>

  <section style="display:grid; grid-template-columns:minmax(0,1fr) 320px; gap:18px; align-items:start;">
    <div style="display:grid; gap:18px;">
      {% for zone,items in componentObligationGroups %}
        <article id="{{ zone|lower|replace({' ':'-', '&':'and', '/':'-'}) }}" style="border:1px solid #dbe3ef; border-radius:18px; background:#fff; overflow:hidden;">
          <header style="display:flex; justify-content:space-between; gap:12px; align-items:center; padding:14px 16px; background:#f8fafc; border-bottom:1px solid #e2e8f0;">
            <div>
              <div style="font-size:12px; color:#64748b; font-weight:800; text-transform:uppercase; letter-spacing:.05em;">Obligation zone</div>
              <h2 style="margin:3px 0 0; font-size:18px;">{{ zone }}</h2>
            </div>
            <span style="font-size:12px; font-weight:800; color:#475569;">{{ items|length }} components</span>
          </header>

          <div style="display:grid; gap:12px; padding:14px;">
            {% for item in items %}
              <section style="border:1px solid #e2e8f0; border-radius:16px; padding:14px; background:#fff;">
                <header style="display:flex; justify-content:space-between; gap:12px; align-items:flex-start; margin-bottom:12px;">
                  <div>
                    <h3 style="margin:0; font-size:17px; color:#0f172a;">{{ item.component }}</h3>
                    <div style="font-size:12px; color:#64748b; margin-top:3px;">{{ item.status }} · {{ item.riskLevel }} obligation risk</div>
                    <p style="margin:8px 0 0; color:#475569; font-size:13px; line-height:1.5;">{{ item.boundary }}</p>
                  </div>
                  <a href="{{ item.primaryUrl }}" style="text-decoration:none; border:1px solid #0f172a; border-radius:10px; padding:7px 10px; font-size:12px; font-weight:900; color:#fff; background:#0f172a; white-space:nowrap;">Primary CRUD</a>
                </header>

                <div style="display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:12px;">
                  <div style="border:1px solid #eef2f7; border-radius:12px; padding:10px; background:#f8fafc;">
                    <strong style="font-size:12px; color:#334155; text-transform:uppercase; letter-spacing:.04em;">Required screens</strong>
                    <ul style="margin:8px 0 0; padding-left:18px; color:#475569; font-size:12px; line-height:1.45;">{% for screen in item.requiredScreens %}<li>{{ screen }}</li>{% endfor %}</ul>
                  </div>
                  <div style="border:1px solid #eef2f7; border-radius:12px; padding:10px; background:#f8fafc;">
                    <strong style="font-size:12px; color:#334155; text-transform:uppercase; letter-spacing:.04em;">Required resources</strong>
                    <ul style="margin:8px 0 0; padding-left:18px; color:#475569; font-size:12px; line-height:1.45;">{% for resource in item.requiredResources %}<li>{{ resource }}</li>{% endfor %}</ul>
                  </div>
                  <div style="border:1px solid #eef2f7; border-radius:12px; padding:10px; background:#fff;">
                    <strong style="font-size:12px; color:#334155; text-transform:uppercase; letter-spacing:.04em;">Fixtures / providers</strong>
                    <ul style="margin:8px 0 0; padding-left:18px; color:#475569; font-size:12px; line-height:1.45;">{% for obligation in item.fixtureObligations %}<li>{{ obligation }}</li>{% endfor %}</ul>
                  </div>
                  <div style="border:1px solid #eef2f7; border-radius:12px; padding:10px; background:#fff;">
                    <strong style="font-size:12px; color:#334155; text-transform:uppercase; letter-spacing:.04em;">Contracts</strong>
                    <ul style="margin:8px 0 0; padding-left:18px; color:#475569; font-size:12px; line-height:1.45;">{% for obligation in item.contractObligations %}<li>{{ obligation }}</li>{% endfor %}</ul>
                  </div>
                  <div style="border:1px solid #eef2f7; border-radius:12px; padding:10px; background:#fff;">
                    <strong style="font-size:12px; color:#334155; text-transform:uppercase; letter-spacing:.04em;">Runtime bridge</strong>
                    <ul style="margin:8px 0 0; padding-left:18px; color:#475569; font-size:12px; line-height:1.45;">{% for obligation in item.runtimeObligations %}<li>{{ obligation }}</li>{% endfor %}</ul>
                  </div>
                  <div style="border:1px solid #eef2f7; border-radius:12px; padding:10px; background:#fff;">
                    <strong style="font-size:12px; color:#334155; text-transform:uppercase; letter-spacing:.04em;">Evidence</strong>
                    <ul style="margin:8px 0 0; padding-left:18px; color:#475569; font-size:12px; line-height:1.45;">{% for obligation in item.evidenceObligations %}<li>{{ obligation }}</li>{% endfor %}</ul>
                  </div>
                </div>
              </section>
            {% endfor %}
          </div>
        </article>
      {% endfor %}
    </div>

    <aside style="display:grid; gap:12px; position:sticky; top:18px;">
      {% include 'interfacing/partial/operation_status_legend.html.twig' only %}
      {% include 'interfacing/partial/crud_route_grammar.html.twig' only %}
      <article style="border:1px solid #e2e8f0; border-radius:16px; background:#fff; padding:14px;">
        <h3 style="margin:0 0 8px; font-size:15px;">No embedded data rule</h3>
        <p style="margin:0; color:#475569; font-size:13px; line-height:1.5;">This page is a checklist. It must not create fake business rows. Components own fixtures, providers, persistence and evidence.</p>
      </article>
    </aside>
  </section>
{% endblock %}
