{% extends 'interfacing/crud/workbench_base.html.twig' %}

{% block title %}{{ workbench.title }}{% endblock %}

{% block crud_workbench_body %}
  <div class="if-stack">
    {% embed 'interfacing/crud/partial/page_head.html.twig' %}
      {% block if_page_head_eyebrow %}<div class="if-eyebrow">{{ workbench.eyebrow }} · {{ workbench.routeContext.surfaceLabel }}</div>{% endblock %}
      {% block if_page_head_title %}{{ workbench.title }}{% endblock %}
      {% block if_page_head_subtitle %}{{ workbench.subtitle }}{% endblock %}
      {% block if_page_head_meta %}
        {% if workbench.breadcrumbs is not empty %}
          <span class="if-chip">breadcrumb: {{ workbench.breadcrumbs|join(' › ') }}</span>
        {% endif %}
        {% for chip in workbench.metaChips %}
          <span class="if-chip">{{ chip }}</span>
        {% endfor %}
      {% endblock %}
      {% block if_page_head_actions %}
        {% for action in workbench.headerActions %}
          <a class="if-button{% if action.variant == 'primary' %} if-button-primary{% elseif action.variant == 'danger' %} if-button-danger{% endif %}" href="{{ action.href }}">{{ action.label }}</a>
        {% endfor %}
      {% endblock %}
    {% endembed %}

    <div class="if-grid">
      {% embed 'interfacing/crud/partial/workbench_panel.html.twig' %}
        {% block if_workbench_panel_title %}{{ workbench.panelTitle }}{% endblock %}
        {% block if_workbench_panel_hint %}{{ workbench.panelHint }}{% endblock %}
        {% block if_workbench_panel_meta %}
          {{ workbench.panelMeta }} · {{ workbench.routeContext.resourcePath }} · {{ workbench.routeContext.operation }} · {{ workbench.routeContext.surface }} · {{ workbench.routeContext.surfaceLabel }} · {{ workbench.routeContext.identifierKindLabel }} · {{ workbench.screenContext.templateToneLabel }}
        {% endblock %}
        {% block if_workbench_panel_filters %}
          <form class="if-filters" method="get">
            {% for field in workbench.filters %}
              {% include 'interfacing/crud/partial/filter_field.html.twig' with {field: field} only %}
            {% endfor %}
            <div class="if-inline-actions">
              <button class="if-button if-button-primary" type="submit">Apply</button>
              <a class="if-button" href="{{ app.request.pathInfo }}">Reset</a>
            </div>
          </form>
        {% endblock %}
        {% block if_workbench_panel_body %}
          {% include 'interfacing/crud/mode/' ~ workbench.routeContext.mode ~ '.html.twig' with {workbench: workbench} only %}
        {% endblock %}
        {% block if_workbench_panel_footer %}
          <div class="if-footer">
            <div>{{ workbench.paginationLabel }}</div>
            <div class="if-section-hint">{{ workbench.screenContext.accessToneLabel }} · {{ workbench.screenContext.mutationToneLabel }} · {{ workbench.screenContext.capabilityLabel }} · {{ workbench.screenContext.ownershipLabel }}</div>
            <div class="if-section-hint">Shared Twig discipline · route semantics driven · mode-aware actions · surface-aware density · identifier-aware addressing · resource-aware wording · resource-aware field vocabulary · resource-aware empty states, sidebar copy, and grouped form validation</div>
          </div>
        {% endblock %}
      {% endembed %}

      {% if workbench.sidebarSections is not empty %}
      <aside class="if-sidebar">
        {% for section in workbench.sidebarSections %}
          {% embed 'interfacing/crud/partial/sidebar_card.html.twig' %}
            {% block if_sidebar_card_title %}{{ section.title }}{% endblock %}
            {% block if_sidebar_card_body %}
              {% if section.facts is not empty %}
                <div class="if-description-list">
                  {% for label, value in section.facts %}
                    <div class="if-description-item">
                      <div class="if-description-term">{{ label }}</div>
                      <div>{{ value ?? '—' }}</div>
                    </div>
                  {% endfor %}
                </div>
              {% endif %}
              {% if section.note %}
                <div class="if-note"{% if section.facts is not empty %} style="margin-top: 12px;"{% endif %}>{{ section.note }}</div>
              {% endif %}
              {% if section.actions is not empty %}
                <div class="if-row-actions" style="margin-top: 12px;">
                  {% for action in section.actions %}
                    <a class="if-button{% if action.variant == 'primary' %} if-button-primary{% elseif action.variant == 'danger' %} if-button-danger{% endif %}" href="{{ action.href }}">{{ action.label }}</a>
                  {% endfor %}
                </div>
              {% endif %}
            {% endblock %}
          {% endembed %}
        {% endfor %}
      </aside>
      {% endif %}
    </div>
  </div>
{% endblock %}
