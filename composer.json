{
  "name": "smartresponsor/interfacing",
  "type": "library",
  "description": "SmartResponsor Interfacing — Symfony-oriented interface runtime, Twig/UX LiveComponent shell, and governed UI platform upstream for ecosystem consumers",
  "license": "proprietary",
  "require": {
    "php": "^8.4",
    "ext-ctype": "*",
    "ext-iconv": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-xml": "*",
    "psr/log": "^3.0",
    "symfony/console": "^8.0",
    "symfony/dependency-injection": "^8.0",
    "symfony/filesystem": "^8.0",
    "symfony/finder": "^8.0",
    "symfony/framework-bundle": "^8.0",
    "symfony/http-client": "^8.0",
    "symfony/http-foundation": "^8.0",
    "symfony/http-kernel": "^8.0",
    "symfony/routing": "^8.0",
    "symfony/security-bundle": "^8.0",
    "symfony/stimulus-bundle": "^2.31",
    "symfony/string": "^8.0",
    "symfony/twig-bundle": "^8.0",
    "symfony/ux-live-component": "^2.31",
    "symfony/ux-twig-component": "^2.31",
    "symfony/validator": "^8.0",
    "symfony/yaml": "^8.0",
    "twig/twig": "^3.24"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.75",
    "phpmd/phpmd": "^2.15",
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^11.5",
    "symfony/browser-kit": "^8.0",
    "symfony/css-selector": "^8.0",
    "symfony/phpunit-bridge": "^8.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/",
      "App\\Test\\": "test/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "scripts": {
    "lint:php": "php tools/qa/php-lint.php src tests test tools",
    "cs:check": "php-cs-fixer fix --dry-run --diff --config=.php-cs-fixer.dist.php",
    "cs:fix": "php-cs-fixer fix --config=.php-cs-fixer.dist.php",
    "stan": "phpstan analyse -c phpstan.neon.dist",
    "md": "phpmd src,text phpmd.xml",
    "test": "phpunit -c phpunit.xml.dist",
    "doctor": "php tools/interfacing/doctor.php",
    "pipeline:local": [
      "@cs:check",
      "@stan",
      "@test"
    ]
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "symfony/flex": true
    }
  },
  "extra": {
    "symfony": {
      "allow-contrib": true,
      "require": "8.0.*"
    }
  }
}
