<div class="card" style="margin-bottom:12px;">
  <div style="display:flex;justify-content:space-between;align-items:center;">
    <div>
      <div style="font-weight:700;">{{ block.props.title }}</div>
      <div style="font-size:12px;color:#6b7280;">updated: {{ component.state.metric.updatedAt ?? 'never' }}</div>
    </div>
    <button
      class="btn"
      data-action="live#action"
      data-live-action-param="invokeAction"
      data-live-action-arg-actionId="{{ block.props.actionId }}"
      data-live-action-arg-payload='{}'
    >Refresh</button>
  </div>

  <div style="font-size:40px;font-weight:800;margin-top:10px;">
    {{ component.state.metric[block.props.metricKey] ?? 0 }}
  </div>
</div>
