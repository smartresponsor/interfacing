<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>Interfacing Doctor</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
      body { font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial; margin: 24px; }
      table { border-collapse: collapse; width: 100%; }
      th, td { border: 1px solid #ddd; padding: 8px; font-size: 14px; }
      th { text-align: left; background: #f6f6f6; }
      code { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New"; }
      .muted { color: #666; }
    </style>
  </head>
  <body>
    <div class="muted">Interfacing Doctor</div>
    <p class="muted">Base context</p>
    <table>
      <tr><th>Key</th><th>Value</th></tr>
      {% for k, v in ctx %}
        <tr><td><code>{{ k }}</code></td><td><code>{{ v }}</code></td></tr>
      {% endfor %}
    </table>

    <p class="muted" style="margin-top: 18px;">Screen permission checks</p>
    <table>
      <tr><th>screenId</th><th>permission</th><th>decision</th><th>reason</th></tr>
      {% for row in screenCheck %}
        <tr>
          <td><code>{{ row.screenId }}</code></td>
          <td><code>{{ row.permission }}</code></td>
          <td><code>{{ row.decision }}</code></td>
          <td class="muted">{{ row.reason }}</td>
        </tr>
      {% endfor %}
    </table>

    <p class="muted" style="margin-top: 18px;">Try:</p>
    <ul class="muted">
      <li><code>GET /interfacing/whoami</code></li>
      <li><code>GET /interfacing/doctor</code> with header <code>X-SR-Tenant: demo</code></li>
      <li><code>php bin/console interfacing:doctor</code></li>
    </ul>
  </body>
</html>
