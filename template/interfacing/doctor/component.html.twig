<div>
  <div style="display:flex; gap: 12px; align-items:center; margin: 12px 0 18px 0;">
    <input type="text" placeholder="search id / title / route"
           style="flex: 1; padding: 10px 12px; border: 1px solid #ddd; border-radius: 10px;"
           data-model="query" />
    <label style="display:flex; align-items:center; gap: 8px; user-select:none;">
      <input type="checkbox" data-model="onlyIssue" {% if onlyIssue %}checked{% endif %}>
      only issue
    </label>
  </div>

  {% set rep = this.report() %}
  {% set issue = rep.issueItem() %}

  <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 14px;">
    <div style="padding: 14px; border: 1px solid #eee; border-radius: 14px;">
      <div style="display:flex; justify-content:space-between; align-items:center;">
        <div style="font-weight: 600;">Issue</div>
        <div style="opacity: .65;">{{ issue|length }}</div>
      </div>

      <div style="margin-top: 10px; display:flex; flex-direction:column; gap: 8px;">
        {% for it in issue %}
          {% if this.match(it.code()) or this.match(it.text()) %}
            <div style="padding: 10px 12px; border: 1px solid #f0f0f0; border-radius: 12px;">
              <div style="display:flex; justify-content:space-between; gap: 10px;">
                <div style="font-weight: 600; font-size: 13px;">{{ it.code() }}</div>
                <div style="opacity: .65; font-size: 13px;">{{ it.level() }}</div>
              </div>
              <div style="margin-top: 6px; font-size: 14px; line-height: 1.35;">{{ it.text() }}</div>
            </div>
          {% endif %}
        {% else %}
          <div style="opacity: .65;">no issue</div>
        {% endfor %}
      </div>
    </div>

    <div style="padding: 14px; border: 1px solid #eee; border-radius: 14px;">
      <div style="display:flex; justify-content:space-between; align-items:center;">
        <div style="font-weight: 600;">Summary</div>
      </div>
      <div style="margin-top: 10px; display:grid; grid-template-columns: 1fr; gap: 8px;">
        <div style="padding: 10px 12px; border: 1px solid #f0f0f0; border-radius: 12px;">
          <div style="display:flex; justify-content:space-between;"><div>screen</div><div style="opacity:.65;">{{ rep.screenItem()|length }}</div></div>
        </div>
        <div style="padding: 10px 12px; border: 1px solid #f0f0f0; border-radius: 12px;">
          <div style="display:flex; justify-content:space-between;"><div>layout</div><div style="opacity:.65;">{{ rep.layoutItem()|length }}</div></div>
        </div>
        <div style="padding: 10px 12px; border: 1px solid #f0f0f0; border-radius: 12px;">
          <div style="display:flex; justify-content:space-between;"><div>action</div><div style="opacity:.65;">{{ rep.actionItem()|length }}</div></div>
        </div>
      </div>
    </div>
  </div>

  <div style="margin-top: 14px; padding: 14px; border: 1px solid #eee; border-radius: 14px;">
    <div style="display:flex; justify-content:space-between; align-items:center;">
      <div style="font-weight: 600;">Screen</div>
      <div style="opacity: .65;">{{ rep.screenItem()|length }}</div>
    </div>

    <div style="margin-top: 10px; display:flex; flex-direction:column; gap: 8px;">
      {% for s in rep.screenItem() %}
        {% set hit = this.match(s.id().value()) or this.match(s.title()) or this.match(s.routePath()) or this.match(s.layoutId().value()) %}
        {% if hit %}
          <div style="padding: 10px 12px; border: 1px solid #f0f0f0; border-radius: 12px;">
            <div style="display:flex; justify-content:space-between; gap: 10px;">
              <div style="font-weight: 600;">{{ s.id().value() }}</div>
              <div style="opacity: .65;">{{ s.tag() }}</div>
            </div>
            <div style="margin-top: 6px; font-size: 14px;">{{ s.title() }}</div>
            <div style="margin-top: 6px; font-size: 13px; opacity: .7;">route: {{ s.routePath() }} · layout: {{ s.layoutId().value() }}</div>
          </div>
        {% endif %}
      {% else %}
        <div style="opacity: .65;">no screen</div>
      {% endfor %}
    </div>
  </div>

  <div style="margin-top: 14px; display:grid; grid-template-columns: 1fr 1fr; gap: 14px;">
    <div style="padding: 14px; border: 1px solid #eee; border-radius: 14px;">
      <div style="display:flex; justify-content:space-between; align-items:center;">
        <div style="font-weight: 600;">Layout</div>
        <div style="opacity: .65;">{{ rep.layoutItem()|length }}</div>
      </div>
      <div style="margin-top: 10px; display:flex; flex-direction:column; gap: 8px;">
        {% for l in rep.layoutItem() %}
          {% if this.match(l.id().value()) or this.match(l.title()) or this.match(l.twigPath()) %}
            <div style="padding: 10px 12px; border: 1px solid #f0f0f0; border-radius: 12px;">
              <div style="font-weight: 600;">{{ l.id().value() }}</div>
              <div style="margin-top: 6px; font-size: 14px;">{{ l.title() }}</div>
              <div style="margin-top: 6px; font-size: 13px; opacity: .7;">twig: {{ l.twigPath() }}</div>
            </div>
          {% endif %}
        {% else %}
          <div style="opacity: .65;">no layout</div>
        {% endfor %}
      </div>
    </div>

    <div style="padding: 14px; border: 1px solid #eee; border-radius: 14px;">
      <div style="display:flex; justify-content:space-between; align-items:center;">
        <div style="font-weight: 600;">Action</div>
        <div style="opacity: .65;">{{ rep.actionItem()|length }}</div>
      </div>
      <div style="margin-top: 10px; display:flex; flex-direction:column; gap: 8px;">
        {% for a in rep.actionItem() %}
          {% if this.match(a.id().value()) %}
            <div style="padding: 10px 12px; border: 1px solid #f0f0f0; border-radius: 12px;">
              <div style="font-weight: 600;">{{ a.id().value() }}</div>
              <div style="margin-top: 6px; font-size: 13px; opacity: .7;">class: {{ a|class_name }}</div>
            </div>
          {% endif %}
        {% else %}
          <div style="opacity: .65;">no action</div>
        {% endfor %}
      </div>
    </div>
  </div>

  <div style="margin-top: 18px; opacity: .65; font-size: 12px;">tip: use `php bin/console interfacing:doctor` for CLI report</div>
</div>
