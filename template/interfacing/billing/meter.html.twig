<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>Billing meter screen</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
      body { font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial; margin: 24px; }
      h1 { font-size: 20px; margin-bottom: 12px; }
      .muted { color: #666; font-size: 13px; }
      table { border-collapse: collapse; width: 100%; margin-top: 12px; }
      th, td { border: 1px solid #ddd; padding: 6px 8px; font-size: 13px; }
      th { text-align: left; background: #f6f6f6; }
      code { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New"; }
      .filters { margin-bottom: 12px; font-size: 13px; }
      .filters label { margin-right: 8px; }
      .filters input { font-size: 13px; padding: 2px 4px; }
      .pager { margin-top: 10px; font-size: 13px; display: flex; gap: 12px; align-items: center; }
      .pager a { text-decoration: none; }
      .pill { display: inline-block; padding: 2px 6px; border-radius: 999px; font-size: 11px; }
      .pill-ok { background: #e6ffed; color: #036400; }
      .pill-warn { background: #fff4e5; color: #8a4b00; }
      .pill-bad { background: #ffecec; color: #8a0000; }
    </style>
  </head>
  <body>
    <h1>Billing meter</h1>
    <div class="muted">
      Screen id: <code>{{ screenId }}</code> · Tenant: <code>{{ ctx.tenantId ?? 'default' }}</code>
    </div>

    <form method="get" class="filters">
      <label>
        Status:
        <input type="text" name="status" value="{{ filters.status }}" placeholder="any">
      </label>
      <label>
        From:
        <input type="date" name="periodFrom" value="{{ filters.periodFrom }}">
      </label>
      <label>
        To:
        <input type="date" name="periodTo" value="{{ filters.periodTo }}">
      </label>
      <button type="submit">Apply</button>
    </form>

    <table>
      <tr>
        <th>Id</th>
        <th>Status</th>
        <th>Amount</th>
        <th>Period</th>
      </tr>
      {% for row in page.items %}
        <tr>
          <td><code>{{ row.id }}</code></td>
          <td>
            {% set cls = 'pill-ok' %}
            {% if row.status starts with 'error' %}
              {% set cls = 'pill-bad' %}
            {% elseif row.status not in ['active', 'ok'] %}
              {% set cls = 'pill-warn' %}
            {% endif %}
            <span class="pill {{ cls }}">{{ row.status }}</span>
          </td>
          <td>{{ row.amount|number_format(2, '.', ',') }}</td>
          <td><span class="muted">{{ row.periodFromIso }} → {{ row.periodToIso }}</span></td>
        </tr>
      {% else %}
        <tr>
          <td colspan="4" class="muted">No rows for current filters.</td>
        </tr>
      {% endfor %}
    </table>

    <div class="pager">
      {% set currentPage = page.page %}
      {% set pageSize = page.pageSize %}
      {% set total = page.total %}
      {% set lastPage = (total > 0) ? ((total - 1) // pageSize + 1) : 1 %}

      <div>
        Page {{ currentPage }} of {{ lastPage }} ({{ total }} rows)
      </div>

      <div>
        {% if currentPage > 1 %}
          <a href="{{ path('interfacing_billing_meter', app.request.query.all|merge({'page': currentPage - 1})) }}">◀ Prev</a>
        {% endif %}
        {% if currentPage < lastPage %}
          <a href="{{ path('interfacing_billing_meter', app.request.query.all|merge({'page': currentPage + 1})) }}">Next ▶</a>
        {% endif %}
      </div>
    </div>
  </body>
</html>
