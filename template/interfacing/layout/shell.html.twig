<!doctype html>
<html>
  <head>
    <meta charset="utf-8">
    <title>{{ layout.active.title }}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
  </head>
  <body>
    <div style="display:flex;gap:16px;min-height:100vh;">
      <aside style="min-width:240px;padding:12px 10px;border-right:1px solid #ddd;">
        <div style="font-weight:600;margin-bottom:10px;">Interfacing</div>
        {% for key, items in layout.navGroup %}
          <div style="margin:14px 0 6px 0;opacity:.75;font-size:12px;text-transform:uppercase;">
            {{ layout.navGroupTitle[key]|default(key) }}
          </div>
          <ul style="margin:0;padding-left:16px;display:flex;flex-direction:column;gap:6px;">
            {% for s in items %}
              <li style="list-style:disc;">
                <a href="{{ path('interfacing_layout_show', { slug: s.slug }) }}"
                   style="{% if s.slug == layout.active.slug %}font-weight:600;{% else %}text-decoration:none;{% endif %}">
                  {{ s.title }}
                </a>
              </li>
            {% endfor %}
          </ul>
        {% endfor %}
      </aside>
      <main style="flex:1;padding:14px 16px;">
        {{ component(screenComponent, { context: screenContext }) }}
      </main>
    </div>
  </body>
</html>
