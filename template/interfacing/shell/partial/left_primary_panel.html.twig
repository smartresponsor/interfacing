<aside title="{{ shellSlotMap['shell.nav.primary']|default('Primary left panel') }}" style="background:#fff; border-right:1px solid #e5e7eb; padding:12px 10px; overflow:auto;">
  {% for g in shellPrimaryGroup %}
    <div style="margin-bottom:12px;">
      <div style="padding:4px 8px; font-size:11px; letter-spacing:.04em; text-transform:uppercase; opacity:.7;">{{ g.title }}</div>
      <div style="display:flex; flex-direction:column; gap:4px;">
        {% for it in g.item %}
          {% set active = shellActiveSection and (shellActiveSection in it.id or shellActiveId == it.id) %}
          <a href="{{ it.url }}" style="display:block; text-decoration:none; color:#111827; border-radius:8px; padding:7px 9px; background:{{ active ? '#eef2ff' : 'transparent' }}; font-size:13px;">
            <div style="font-weight:600;">{{ it.title }}</div>
          </a>
        {% endfor %}
      </div>
    </div>
  {% endfor %}
</aside>
