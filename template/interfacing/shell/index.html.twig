{% extends 'interfacing/base.html.twig' %}

{% block body %}
  <section style="background:#fff; border:1px solid #dbe1ea; border-radius:16px; padding:14px 16px; margin-bottom:14px;">
    <div style="font-size:12px; font-weight:700; color:#2563eb; text-transform:uppercase; letter-spacing:.05em;">Legacy screen host</div>
    <h1 style="margin:6px 0 0; font-size:28px; line-height:1.05;">{{ payload.screen.title ?? activeScreenId }}</h1>
    <div style="margin-top:8px; color:#64748b; font-size:13px;">Legacy screen renderer normalized into the standard shell.</div>
  </section>

  <div style="background:#fff; border:1px solid #dbe1ea; border-radius:16px; padding:16px;">
    {% include activeViewId ~ '.html.twig' with {'payload': payload} %}
  </div>
{% endblock %}
