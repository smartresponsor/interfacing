{% extends 'interfacing/base.html.twig' %}

{% block body %}
  {% include 'interfacing/partial/admin_toolbar.html.twig' with {
    eyebrow: 'Contract registry',
    title: 'Runtime CRUD contract registry',
    summary: 'Formalizes the screen, data, operation, policy and evidence contracts that owning components must publish before Interfacing treats CRUD screens as connected runtime surfaces.',
    actions: [
      { label: 'Evidence Registry', url: path('interfacing_evidence_registry') },
      { label: 'Promotion Gates', url: path('interfacing_promotion_gates') },
      { label: 'Runtime Bridges', url: path('interfacing_runtime_bridges') },
      { label: 'CRUD Readiness', url: path('interfacing_crud_readiness') }
    ]
  } only %}

  <section style="display:grid; grid-template-columns:repeat(4,minmax(0,1fr)); gap:12px; margin:0 0 18px;">
    {% for key,label in {'total':'Contract rows','missing':'Missing','draft':'Draft','formalized':'Formalized'} %}
      <article style="border:1px solid #e2e8f0; border-radius:16px; padding:14px; background:#fff;">
        <div style="font-size:12px; color:#64748b; font-weight:800; text-transform:uppercase; letter-spacing:.04em;">{{ label }}</div>
        <div style="font-size:28px; font-weight:900; color:#0f172a; margin-top:4px;">{{ contractGradeCounts[key]|default(0) }}</div>
      </article>
    {% endfor %}
  </section>

  <section style="display:grid; grid-template-columns:minmax(0,1fr) 320px; gap:18px; align-items:start;">
    <div style="display:grid; gap:18px;">
      {% for zone,items in contractGroups %}
        <article id="{{ zone|lower|replace({' ':'-', '&':'and', '/':'-'}) }}" style="border:1px solid #dbe3ef; border-radius:18px; background:#fff; overflow:hidden;">
          <header style="display:flex; justify-content:space-between; gap:12px; align-items:center; padding:14px 16px; background:#f8fafc; border-bottom:1px solid #e2e8f0;">
            <div>
              <div style="font-size:12px; color:#64748b; font-weight:800; text-transform:uppercase; letter-spacing:.05em;">Contract zone</div>
              <h2 style="margin:3px 0 0; font-size:18px;">{{ zone }}</h2>
            </div>
            <span style="font-size:12px; font-weight:800; color:#475569;">{{ items|length }} components</span>
          </header>

          <div style="display:grid; gap:12px; padding:14px;">
            {% for item in items %}
              <section style="border:1px solid #e2e8f0; border-radius:16px; padding:14px; background:#fff;">
                <header style="display:flex; justify-content:space-between; gap:12px; align-items:flex-start; margin-bottom:12px;">
                  <div>
                    <h3 style="margin:0; font-size:17px; color:#0f172a;">{{ item.component }}</h3>
                    <div style="font-size:12px; color:#64748b; margin-top:3px;">{{ item.status }} · {{ item.contractGrade }} · score {{ item.score }}</div>
                    <p style="margin:8px 0 0; color:#475569; font-size:13px; line-height:1.5;">{{ item.note }}</p>
                  </div>
                  <a href="{{ item.primaryUrl }}" style="text-decoration:none; border:1px solid #0f172a; border-radius:10px; padding:7px 10px; font-size:12px; font-weight:900; color:#fff; background:#0f172a; white-space:nowrap;">Primary CRUD</a>
                </header>

                <div style="display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:12px;">
                  <div style="border:1px solid #eef2f7; border-radius:12px; padding:10px; background:#f8fafc;">
                    <strong style="font-size:12px; color:#334155; text-transform:uppercase; letter-spacing:.04em;">Screen + data contracts</strong>
                    <ul style="margin:8px 0 0; padding-left:18px; color:#475569; font-size:12px; line-height:1.45;">
                      {% for contract in item.screenContracts %}<li>{{ contract }}</li>{% endfor %}
                      {% for contract in item.dataContracts %}<li>{{ contract }}</li>{% endfor %}
                    </ul>
                  </div>
                  <div style="border:1px solid #eef2f7; border-radius:12px; padding:10px; background:#fff;">
                    <strong style="font-size:12px; color:#334155; text-transform:uppercase; letter-spacing:.04em;">Operation + policy contracts</strong>
                    <ul style="margin:8px 0 0; padding-left:18px; color:#475569; font-size:12px; line-height:1.45;">
                      {% for contract in item.operationContracts %}<li>{{ contract }}</li>{% endfor %}
                      {% for contract in item.policyContracts %}<li>{{ contract }}</li>{% endfor %}
                    </ul>
                  </div>
                  <div style="border:1px solid #eef2f7; border-radius:12px; padding:10px; background:#fff;">
                    <strong style="font-size:12px; color:#334155; text-transform:uppercase; letter-spacing:.04em;">Evidence + open questions</strong>
                    <ul style="margin:8px 0 0; padding-left:18px; color:#475569; font-size:12px; line-height:1.45;">
                      {% for contract in item.evidenceContracts %}<li>{{ contract }}</li>{% endfor %}
                      {% for question in item.openQuestions %}<li>{{ question }}</li>{% endfor %}
                    </ul>
                  </div>
                </div>
              </section>
            {% endfor %}
          </div>
        </article>
      {% endfor %}
    </div>

    <aside style="display:grid; gap:12px; position:sticky; top:18px;">
      <article style="border:1px solid #e2e8f0; border-radius:16px; background:#fff; padding:14px;">
        <h3 style="margin:0 0 8px; font-size:15px;">Contract grade</h3>
        <div style="display:grid; gap:8px; font-size:13px; color:#475569;">
          <div><strong>missing</strong> — component is known, but owner contracts are not published.</div>
          <div><strong>draft</strong> — canonical resource exists; runtime contract proof remains incomplete.</div>
          <div><strong>formalized</strong> — connected component has screen/data/operation/policy/evidence contracts.</div>
        </div>
      </article>
      <article style="border:1px solid #e2e8f0; border-radius:16px; background:#fff; padding:14px;">
        <h3 style="margin:0 0 8px; font-size:15px;">Boundary</h3>
        <p style="margin:0; color:#475569; font-size:13px; line-height:1.5;">Interfacing owns shell, route grammar, frames, tables and operation affordances. Owning components own records, fixtures, identifiers, field schema, handlers, authorization and audit proof.</p>
      </article>
      {% include 'interfacing/partial/crud_route_grammar.html.twig' only %}
    </aside>
  </section>
{% endblock %}
