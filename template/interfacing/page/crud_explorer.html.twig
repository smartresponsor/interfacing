{% extends 'interfacing/base.html.twig' %}

{% block body %}
  <section style="background:#fff; border:1px solid #dbe1ea; border-radius:16px; padding:14px 16px; margin-bottom:14px;">
    <div style="display:flex; justify-content:space-between; gap:12px; align-items:flex-start;">
      <div>
        <div style="font-size:12px; font-weight:700; color:#2563eb; text-transform:uppercase; letter-spacing:.05em;">Cruding → Interfacing</div>
        <h1 style="margin:6px 0 0; font-size:28px; line-height:1.05; letter-spacing:-.03em;">CRUD Explorer</h1>
        <div style="margin-top:8px; font-size:13px; color:#64748b; max-width:960px;">One screen for discovering canonical CRUD entry points across connected and planned ecosystem resources. Use it to open index/new flows first, then inspect canonical show/edit/delete grammar before asking bridges for deeper custom screens.</div>
      </div>
      <div style="display:flex; gap:8px; flex-wrap:wrap; justify-content:flex-end;">
        <a href="{{ path('interfacing_index') }}" style="text-decoration:none; padding:9px 12px; border-radius:11px; background:#fff; color:#0f172a; border:1px solid #cbd5e1; font-weight:600; font-size:12px;">Workspace</a>
        <a href="#crud-pattern" style="text-decoration:none; padding:9px 12px; border-radius:11px; background:#2563eb; color:#fff; font-weight:700; font-size:12px;">Route grammar</a>
      </div>
    </div>
  </section>

  <section style="display:grid; grid-template-columns:minmax(0,2.1fr) minmax(320px,.9fr); gap:14px; align-items:start;">
    <div style="display:flex; flex-direction:column; gap:14px;">
      {% for component, resources in resourceGroups %}
        <section style="display:flex; flex-direction:column; gap:10px;">
          <div style="display:flex; justify-content:space-between; align-items:flex-end; gap:10px;">
            <div>
              <div style="font-size:11px; color:#2563eb; text-transform:uppercase; font-weight:700; letter-spacing:.05em;">Known ecosystem component</div>
              <div style="margin-top:4px; font-size:20px; font-weight:800; line-height:1.1;">{{ component }}</div>
            </div>
            <div style="font-size:12px; color:#64748b;">{{ resources|length }} CRUD resource{% if resources|length != 1 %}s{% endif %}</div>
          </div>
          {% for resource in resources %}
            <article style="background:#fff; border:1px solid #dbe1ea; border-radius:16px; padding:14px 16px;">
          <div style="display:flex; justify-content:space-between; gap:12px; align-items:flex-start;">
            <div>
              <div style="font-size:11px; color:#2563eb; text-transform:uppercase; font-weight:700; letter-spacing:.05em;">{{ resource.component }}</div>
              <div style="margin-top:6px; font-size:20px; font-weight:800; line-height:1.1;">{{ resource.label }}</div>
              <div style="margin-top:4px; font-size:12px; color:#64748b;">resourcePath · {{ resource.resourcePath }}</div>
            </div>
            <div style="display:flex; gap:8px; flex-wrap:wrap; justify-content:flex-end;">
              <a href="{{ resource.indexUrl }}" style="text-decoration:none; padding:8px 11px; border-radius:10px; background:#0f172a; color:#fff; font-weight:700; font-size:12px;">Open index</a>
              <a href="{{ resource.newUrl }}" style="text-decoration:none; padding:8px 11px; border-radius:10px; background:#fff; color:#0f172a; border:1px solid #cbd5e1; font-weight:600; font-size:12px;">Create new</a>
            </div>
          </div>
          <div style="margin-top:12px; display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:10px;">
            <div style="padding:10px 11px; border:1px solid #e2e8f0; border-radius:12px;">
              <div style="font-size:11px; color:#64748b; text-transform:uppercase;">Show</div>
              <div style="margin-top:6px; font-size:12px; font-family:ui-monospace,SFMono-Regular,Consolas,monospace;">{{ resource.showPattern }}</div>
            </div>
            <div style="padding:10px 11px; border:1px solid #e2e8f0; border-radius:12px;">
              <div style="font-size:11px; color:#64748b; text-transform:uppercase;">Edit</div>
              <div style="margin-top:6px; font-size:12px; font-family:ui-monospace,SFMono-Regular,Consolas,monospace;">{{ resource.editPattern }}</div>
            </div>
            <div style="padding:10px 11px; border:1px solid #e2e8f0; border-radius:12px;">
              <div style="font-size:11px; color:#64748b; text-transform:uppercase;">Delete</div>
              <div style="margin-top:6px; font-size:12px; font-family:ui-monospace,SFMono-Regular,Consolas,monospace;">{{ resource.deletePattern }}</div>
            </div>
          </div>
          {% if resource.note %}
            <div style="margin-top:10px; font-size:12px; color:#475569;">{{ resource.note }}</div>
          {% endif %}
            </article>
          {% endfor %}
        </section>
      {% endfor %}
    </div>

    <aside style="display:flex; flex-direction:column; gap:12px;">
      <section id="crud-pattern" style="background:#fff; border:1px solid #dbe1ea; border-radius:16px; padding:14px 16px;">
        <div style="font-size:11px; color:#2563eb; text-transform:uppercase; font-weight:700; letter-spacing:.05em;">Canonical grammar</div>
        <div style="margin-top:8px; display:flex; flex-direction:column; gap:8px; font-size:12px; color:#334155;">
          <div><strong>Index</strong> · <span style="font-family:ui-monospace,SFMono-Regular,Consolas,monospace;">/{resourcePath}/</span></div>
          <div><strong>New</strong> · <span style="font-family:ui-monospace,SFMono-Regular,Consolas,monospace;">/{resourcePath}/new/</span></div>
          <div><strong>Show</strong> · <span style="font-family:ui-monospace,SFMono-Regular,Consolas,monospace;">/{resourcePath}/{id|slug}</span></div>
          <div><strong>Edit</strong> · <span style="font-family:ui-monospace,SFMono-Regular,Consolas,monospace;">/{resourcePath}/edit/{id|slug}</span></div>
          <div><strong>Delete</strong> · <span style="font-family:ui-monospace,SFMono-Regular,Consolas,monospace;">/{resourcePath}/delete/{id|slug}</span></div>
        </div>
      </section>
      <section style="background:#fff; border:1px solid #dbe1ea; border-radius:16px; padding:14px 16px;">
        <div style="font-size:11px; color:#2563eb; text-transform:uppercase; font-weight:700; letter-spacing:.05em;">Why this screen exists</div>
        <div style="margin-top:8px; font-size:12px; color:#475569; line-height:1.45;">This is the shell-native place to audit which connected or planned resources already expose canonical CRUD entry points. Custom component bridges stay separate; generic CRUD discovery belongs here.</div>
        <div style="margin-top:10px; font-size:12px; color:#64748b;">Known resources listed here: {{ resourceSet|length }}</div>
      </section>
    </aside>
  </section>
{% endblock %}
