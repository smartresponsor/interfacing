{% set s = this.spec %}
{% set p = this.progress %}
{% set step = this.step %}

<div style="background:#fff;border:1px solid #e6e6e6;border-radius:14px;padding:12px;">
  <div style="display:flex;justify-content:space-between;gap:10px;align-items:flex-start;margin-bottom:10px;">
    <div>
      <div style="font-weight:700;">{{ s.title }}</div>
      <div style="opacity:.7;font-size:12px;margin-top:4px;">Step {{ p.index + 1 }} / {{ p.total }} — {{ step.title }}</div>
      {% if step.hint %}
        <div style="opacity:.7;font-size:12px;margin-top:4px;">{{ step.hint }}</div>
      {% endif %}
    </div>
    <div style="opacity:.65;font-size:12px;">handler: {{ this.handlerId }}</div>
  </div>

  <div style="height:8px;background:#eee;border-radius:999px;overflow:hidden;margin-bottom:12px;">
    <div style="height:8px;background:#999;width:{{ p.percent }}%;"></div>
  </div>

  {% if this.flash %}
    <div style="margin-bottom:10px;padding:8px 10px;border:1px solid #eee;border-radius:10px;">
      {{ this.flash }}
    </div>
  {% endif %}

  <div style="display:flex;flex-direction:column;gap:10px;">
    {% for f in step.field %}
      <div>
        <div style="display:flex;gap:8px;align-items:center;margin-bottom:4px;">
          <div style="font-size:12px;opacity:.8;">{{ f.title }}{% if f.required %} *{% endif %}</div>
          {% set err = this.fieldErrorFor(f.id) %}
          {% if err %}
            <div style="font-size:12px;color:crimson;">{{ err }}</div>
          {% endif %}
        </div>

        {% if f.type == 'textarea' %}
          <textarea data-model="value[{{ f.id }}]" rows="4" placeholder="{{ f.placeholder }}" style="width:100%;padding:8px 10px;border:1px solid #ddd;border-radius:10px;"></textarea>
        {% elseif f.type == 'select' %}
          <select data-model="value[{{ f.id }}]" style="width:100%;padding:8px 10px;border:1px solid #ddd;border-radius:10px;">
            {% for o in f.option %}
              <option value="{{ o.value }}">{{ o.label }}</option>
            {% endfor %}
          </select>
        {% elseif f.type == 'checkbox' %}
          <label style="display:flex;gap:8px;align-items:center;">
            <input type="checkbox" data-model="value[{{ f.id }}]">
            <span style="font-size:12px;opacity:.85;">enabled</span>
          </label>
        {% else %}
          <input type="{{ f.type }}" data-model="value[{{ f.id }}]" placeholder="{{ f.placeholder }}" style="width:100%;padding:8px 10px;border:1px solid #ddd;border-radius:10px;">
        {% endif %}
      </div>
    {% endfor %}

    <div style="display:flex;gap:8px;align-items:center;margin-top:4px;">
      {% if not p.isFirst %}
        <button type="button" data-action="live#action" data-live-action-param="back" style="padding:8px 12px;border-radius:10px;border:1px solid #ddd;background:#fff;">Back</button>
      {% endif %}

      {% if not p.isLast %}
        <button type="button" data-action="live#action" data-live-action-param="next" style="padding:8px 12px;border-radius:10px;border:1px solid #ddd;background:#fff;">Next</button>
      {% else %}
        <button type="button" data-action="live#action" data-live-action-param="finish" style="padding:8px 12px;border-radius:10px;border:1px solid #ddd;background:#fff;">{{ s.finishLabel }}</button>
      {% endif %}

      <button type="button" data-action="live#action" data-live-action-param="reset" style="padding:8px 12px;border-radius:10px;border:1px solid #ddd;background:#fff;">Reset</button>
    </div>
  </div>
</div>
