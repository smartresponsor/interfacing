{% set shell = shell|default({}) %}
{% set fallbackTopLink = [
  {'id': 'workspace', 'title': 'Workspace', 'url': '/interfacing'},
  {'id': 'applications', 'title': 'Applications', 'url': '/interfacing/components'},
  {'id': 'crud.explorer', 'title': 'CRUD Explorer', 'url': '/interfacing/crud/explorer'},
  {'id': 'screen.directory', 'title': 'Screens', 'url': '/interfacing/screens'},
  {'id': 'operation.workbench', 'title': 'Operations', 'url': '/interfacing/operations'},
  {'id': 'layout.preview', 'title': 'Layout', 'url': '/interfacing/shell/layout-preview'},
  {'id': 'shell.guard', 'title': 'Shell Guard', 'url': '/interfacing/shell/diagnostics'}
] %}
{% set fallbackPrimaryGroup = [
  {'title': 'Workspace', 'item': [
    {'id': 'workspace.home', 'title': 'Overview', 'url': '/interfacing'},
    {'id': 'applications.dashboard', 'title': 'Application dashboard', 'url': '/interfacing/components'},
    {'id': 'screen.directory', 'title': 'Screen directory', 'url': '/interfacing/screens'},
    {'id': 'operation.workbench', 'title': 'Operation workbench', 'url': '/interfacing/operations'}
  ]},
  {'title': 'CRUD', 'item': [
    {'id': 'crud.explorer', 'title': 'CRUD explorer', 'url': '/interfacing/crud/explorer'},
    {'id': 'admin.tables', 'title': 'Admin tables', 'url': '/interfacing/tables'},
    {'id': 'crud.frames', 'title': 'CRUD forms', 'url': '/interfacing/forms'},
    {'id': 'crud.affordances', 'title': 'CRUD affordances', 'url': '/interfacing/affordances'},
    {'id': 'crud.readiness', 'title': 'CRUD readiness', 'url': '/interfacing/readiness'}
  ]},
  {'title': 'Shell', 'item': [
    {'id': 'layout.preview', 'title': 'Layout preview', 'url': '/interfacing/shell/layout-preview'},
    {'id': 'shell.diagnostics', 'title': 'Shell diagnostics', 'url': '/interfacing/shell/diagnostics'},
    {'id': 'shell.navigation', 'title': 'Navigation map', 'url': '/interfacing/shell/navigation'},
    {'id': 'shell.screens', 'title': 'Shell screens', 'url': '/interfacing/shell/screens'}
  ]}
] %}
{% set fallbackSectionGroup = [
  {'title': 'Known components', 'item': [
    {'id': 'cataloging.category', 'title': 'Cataloging · Category', 'url': '/category/'},
    {'id': 'ordering.order', 'title': 'Ordering · Order', 'url': '/order/'},
    {'id': 'paying.payment', 'title': 'Paying · Payment', 'url': '/payment/'},
    {'id': 'shipping.shipment', 'title': 'Shipping · Shipment', 'url': '/shipment/'},
    {'id': 'messaging.message', 'title': 'Messaging · Message', 'url': '/message/'},
    {'id': 'tagging.tag', 'title': 'Tagging · Tag', 'url': '/tag/'},
    {'id': 'locating.location', 'title': 'Locating · Location', 'url': '/location/'},
    {'id': 'indexing.record', 'title': 'Indexing · Index record', 'url': '/index-record/'}
  ]},
  {'title': 'Standard operations', 'item': [
    {'id': 'operation.index', 'title': 'Index tables', 'url': '/interfacing/tables'},
    {'id': 'operation.new', 'title': 'Create forms', 'url': '/interfacing/forms'},
    {'id': 'operation.show', 'title': 'Details', 'url': '/interfacing/crud/explorer'},
    {'id': 'operation.edit', 'title': 'Edit forms', 'url': '/interfacing/forms'},
    {'id': 'operation.delete', 'title': 'Delete confirmations', 'url': '/interfacing/affordances'}
  ]}
] %}
{% set fallbackRightPanelGroup = [
  {'title': 'CRUD shortcuts', 'item': [
    {'id': 'crud.links', 'title': 'Links JSON', 'url': '/interfacing/crud/explorer/links.json'},
    {'id': 'crud.routes', 'title': 'Route expectations', 'url': '/interfacing/crud/explorer/route-expectations.json'},
    {'id': 'crud.screens', 'title': 'Screens JSON', 'url': '/interfacing/crud/explorer/screens.json'},
    {'id': 'crud.operations', 'title': 'Operations JSON', 'url': '/interfacing/crud/explorer/operations.json'}
  ]},
  {'title': 'Layout contract', 'item': [
    {'id': 'layout.preview', 'title': '4-column / 3-column preview', 'url': '/interfacing/shell/layout-preview'},
    {'id': 'shell.diagnostics', 'title': 'Panel diagnostics', 'url': '/interfacing/shell/diagnostics'},
    {'id': 'shell.navigation', 'title': 'Navigation map', 'url': '/interfacing/shell/navigation'}
  ]}
] %}
{% set fallbackFooterGroup = [
  {'title': 'Explore', 'link': [
    {'title': 'Workspace', 'url': '/interfacing'},
    {'title': 'Applications', 'url': '/interfacing/components'},
    {'title': 'CRUD Explorer', 'url': '/interfacing/crud/explorer'},
    {'title': 'Shell Guard', 'url': '/interfacing/shell/diagnostics'}
  ]},
  {'title': 'Operations', 'link': [
    {'title': 'Tables', 'url': '/interfacing/tables'},
    {'title': 'Forms', 'url': '/interfacing/forms'},
    {'title': 'Affordances', 'url': '/interfacing/affordances'},
    {'title': 'Readiness', 'url': '/interfacing/readiness'}
  ]},
  {'title': 'Host shell', 'link': [
    {'title': 'Layout Preview', 'url': '/interfacing/shell/layout-preview'},
    {'title': 'Navigation Map', 'url': '/interfacing/shell/navigation'},
    {'title': 'Screen Catalog', 'url': '/interfacing/shell/screens'}
  ]}
] %}
{% set shellTopLink = shell.topLink is defined and shell.topLink is not empty ? shell.topLink : fallbackTopLink %}
{% set shellPrimaryGroup = shell.primaryGroup is defined and shell.primaryGroup is not empty ? shell.primaryGroup : fallbackPrimaryGroup %}
{% set shellSectionGroup = shell.sectionGroup is defined and shell.sectionGroup is not empty ? shell.sectionGroup : fallbackSectionGroup %}
{% set shellRightPanelGroup = shell.rightPanelGroup is defined and shell.rightPanelGroup is not empty ? shell.rightPanelGroup : fallbackRightPanelGroup %}
{% set shellFooterGroup = shell.footerGroup is defined and shell.footerGroup is not empty ? shell.footerGroup : fallbackFooterGroup %}
{% set shellQuery = shell.query is defined ? shell.query : app.request.query.get('q', '') %}
{% set shellActiveId = shell.activeId is defined ? shell.activeId : null %}
{% set shellActiveSection = shell.activeSection is defined ? shell.activeSection : 'workspace' %}
{% set shellRightPanelEnabled = shell.rightPanelEnabled is defined ? shell.rightPanelEnabled : true %}
{% set shellMode = shellRightPanelEnabled ? 'four-column' : 'three-column' %}
{% set shellSlotMap = shell.slotMap is defined ? shell.slotMap : {} %}
<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title|default('Smart Responsor') }}</title>
  <link rel="icon" href="/favicon.ico">
  <link rel="icon" type="image/svg+xml" href="/mandala.svg">
  <link rel="apple-touch-icon" href="/mandala.svg">
  {% block head_extra %}{% endblock %}
</head>
<body style="font-family:system-ui,-apple-system,Segoe UI,Roboto,Ubuntu; margin:0; background:#f3f4f6; color:#111827;">
  <div data-sr-shell="host-wide" data-sr-shell-mode="{{ shellMode }}" style="min-height:100vh; display:grid; grid-template-rows:auto 1fr auto;">
    <header data-sr-shell-slot="top" style="border-bottom:1px solid #dbe1e8; background:#fff; position:sticky; top:0; z-index:20;">
      <div style="max-width:1680px; margin:0 auto; display:grid; grid-template-columns:minmax(220px,auto) minmax(320px,1fr) auto; align-items:center; gap:14px; padding:10px 14px;">
        <a href="/interfacing" style="text-decoration:none; color:#111827; display:block; min-width:0;">
          <div style="font-weight:800; font-size:14px; line-height:1.2;">Smart Responsor</div>
          <div style="font-size:11px; opacity:.65;">Host-wide application shell</div>
        </a>
        <form method="get" action="{{ app.request.pathInfo }}" style="display:grid; grid-template-columns:minmax(160px,1fr) 150px 140px auto; gap:8px; align-items:center;">
          <input name="q" value="{{ shellQuery }}" placeholder="Filter screens, components, entities, CRUD resources..." style="width:100%; box-sizing:border-box; padding:8px 10px; border:1px solid #cfd6df; border-radius:8px; font-size:12px;">
          <select name="scope" aria-label="Shell filter scope" style="padding:8px 10px; border:1px solid #cfd6df; border-radius:8px; font-size:12px; background:#fff;">
            <option value="all">All zones</option>
            <option value="crud">CRUD</option>
            <option value="component">Components</option>
            <option value="screen">Screens</option>
          </select>
          <select name="status" aria-label="Shell filter status" style="padding:8px 10px; border:1px solid #cfd6df; border-radius:8px; font-size:12px; background:#fff;">
            <option value="all">Any status</option>
            <option value="connected">Connected</option>
            <option value="canonical">Canonical</option>
            <option value="planned">Planned</option>
          </select>
          <button type="submit" style="padding:8px 11px; border:1px solid #111827; border-radius:8px; background:#111827; color:#fff; font-size:12px; font-weight:700;">Filter</button>
        </form>
        <nav title="{{ shellSlotMap['shell.topbar.right']|default('Top panel') }}" style="display:flex; align-items:center; gap:8px; flex-wrap:wrap; justify-content:flex-end;">
          {% for it in shellTopLink %}
            <a href="{{ it.url }}" style="text-decoration:none; color:#111827; border:1px solid #d7dde5; background:#f8fafc; border-radius:8px; padding:6px 9px; font-size:12px;">{{ it.title }}</a>
          {% endfor %}
        </nav>
      </div>
    </header>

    <div style="display:grid; grid-template-columns:260px 230px minmax(0, 1fr){{ shellRightPanelEnabled ? ' 280px' : '' }}; gap:0; min-height:0;">
      <aside data-sr-shell-slot="left-primary" title="{{ shellSlotMap['shell.nav.primary']|default('Primary left panel') }}" style="background:#fff; border-right:1px solid #e5e7eb; padding:12px 10px; overflow:auto;">
        {% for g in shellPrimaryGroup %}
          <section style="margin-bottom:12px;">
            <div style="padding:4px 8px; font-size:11px; letter-spacing:.04em; text-transform:uppercase; opacity:.7; font-weight:700;">{{ g.title }}</div>
            <div style="display:flex; flex-direction:column; gap:4px;">
              {% for it in g.item %}
                {% set active = shellActiveId and shellActiveId == it.id %}
                <a href="{{ it.url }}" style="display:block; text-decoration:none; color:#111827; border-radius:8px; padding:7px 9px; background:{{ active ? '#eef2ff' : 'transparent' }}; font-size:13px;">
                  <span style="font-weight:650;">{{ it.title }}</span>
                </a>
              {% endfor %}
            </div>
          </section>
        {% endfor %}
      </aside>

      <aside data-sr-shell-slot="left-secondary" title="{{ shellSlotMap['shell.nav.section']|default('Secondary left panel') }}" style="background:#fbfcfd; border-right:1px solid #e5e7eb; padding:12px 10px; overflow:auto;">
        {% for g in shellSectionGroup %}
          <section style="margin-bottom:12px;">
            <div style="padding:4px 8px; font-size:11px; letter-spacing:.04em; text-transform:uppercase; opacity:.72; font-weight:700;">{{ g.title }}</div>
            <div style="display:flex; flex-direction:column; gap:4px;">
              {% for it in g.item %}
                {% set active = shellActiveId and shellActiveId == it.id %}
                <a href="{{ it.url }}" style="display:block; text-decoration:none; color:#111827; border-radius:8px; padding:7px 9px; background:{{ active ? '#eaf7ef' : 'transparent' }}; font-size:12px;">
                  <div style="font-weight:650;">{{ it.title }}</div>
                  <div style="opacity:.55; font-size:11px; margin-top:1px;">{{ it.id }}</div>
                </a>
              {% endfor %}
            </div>
          </section>
        {% endfor %}
      </aside>

      <main data-sr-shell-slot="body" title="{{ shellSlotMap['shell.content.body']|default('Content body') }}" style="min-width:0; padding:14px 16px 18px 16px; overflow:auto;">
        <div style="max-width:1320px; margin:0 auto;">
          {% block body %}{% endblock %}
        </div>
      </main>

      {% if shellRightPanelEnabled %}
        <aside data-sr-shell-slot="right-context" title="{{ shellSlotMap['shell.context.right']|default('Right context panel') }}" style="background:#fff; border-left:1px solid #e5e7eb; padding:12px 10px; overflow:auto;">
          <div style="font-size:11px; text-transform:uppercase; letter-spacing:.04em; opacity:.7; font-weight:800; margin:4px 8px 10px;">Context</div>
          {% for g in shellRightPanelGroup %}
            <section style="margin-bottom:14px; border:1px solid #e5e7eb; border-radius:12px; padding:9px; background:#fcfcfd;">
              <div style="font-size:12px; font-weight:800; margin-bottom:7px;">{{ g.title }}</div>
              <div style="display:flex; flex-direction:column; gap:5px;">
                {% for it in g.item %}
                  <a href="{{ it.url }}" style="text-decoration:none; color:#111827; font-size:12px; border-radius:7px; padding:6px 7px; background:#fff; border:1px solid #edf0f3;">{{ it.title }}</a>
                {% endfor %}
              </div>
            </section>
          {% endfor %}
        </aside>
      {% endif %}
    </div>

    <footer data-sr-shell-slot="footer" style="border-top:1px solid #dbe1e8; background:#fff;">
      <div style="max-width:1680px; margin:0 auto; display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:18px; padding:12px 14px;">
        {% for g in shellFooterGroup %}
          <section>
            <div style="font-size:11px; letter-spacing:.04em; text-transform:uppercase; opacity:.68; margin-bottom:6px; font-weight:800;">{{ g.title }}</div>
            <div style="display:flex; flex-wrap:wrap; gap:8px 12px;">
              {% for link in g.link %}
                <a href="{{ link.url }}" style="text-decoration:none; color:#111827; opacity:.82; font-size:12px;">{{ link.title }}</a>
              {% endfor %}
            </div>
          </section>
        {% endfor %}
      </div>
    </footer>
  </div>
</body>
</html>
