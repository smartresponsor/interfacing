<div {{ attributes }}>
  {% if uiMessage is defined and uiMessage is not empty %}
    <div style="margin: 0 0 10px 0;">
      {% for m in uiMessage %}
        <div style="padding: 10px 12px; border-radius: 10px; border: 1px solid #ddd; margin: 0 0 6px 0;">
          <span style="font-weight: 600;">{{ m.type|upper }}</span>
          <span style="margin-left: 8px;">{{ m.text }}</span>
        </div>
      {% endfor %}
    </div>
  {% endif %}

  {% if uiError.global is defined and uiError.global is not empty %}
    <div style="margin: 0 0 10px 0;">
      {% for e in uiError.global %}
        <div style="padding: 10px 12px; border-radius: 10px; border: 1px solid #f2c; margin: 0 0 6px 0;">
          {{ e.message }}
        </div>
      {% endfor %}
    </div>
  {% endif %}

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
    <div>
      <label style="display:block; font-size: 13px; margin: 0 0 4px 0;">Name</label>
      <input type="text" data-model="name" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 10px;">
      {% if uiError.field.name is defined %}
        {% for e in uiError.field.name %}
          <div style="color: #c00; font-size: 12px; margin-top: 4px;">{{ e.message }}</div>
        {% endfor %}
      {% endif %}
    </div>

    <div>
      <label style="display:block; font-size: 13px; margin: 0 0 4px 0;">Email</label>
      <input type="email" data-model="email" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 10px;">
      {% if uiError.field.email is defined %}
        {% for e in uiError.field.email %}
          <div style="color: #c00; font-size: 12px; margin-top: 4px;">{{ e.message }}</div>
        {% endfor %}
      {% endif %}
    </div>
  </div>

  <div style="margin-top: 12px;">
    <button data-action="live#action" data-live-action-param="save"
      style="padding: 10px 14px; border-radius: 10px; border: 1px solid #111; background: #111; color: #fff; cursor: pointer;">
      Save
    </button>
  </div>

  <div style="margin-top: 10px; font-size: 12px; color: #666;">
    Try email: blocked@example.com (demo domain error)
  </div>
</div>
