<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ shell.title|e }} - Interfacing</title>
  <style>
    body { margin:0; font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; color:#111; background:#f5f5f5; }
    .shell { display:flex; min-height: 100vh; }
    .nav { width: 260px; background:#fff; border-right: 1px solid #e5e5e5; padding: 14px 12px; box-sizing: border-box; }
    .main { flex:1; padding: 18px; box-sizing: border-box; }
    .card { background:#fff; border: 1px solid #e5e5e5; border-radius: 12px; padding: 14px; }
    .title { font-size: 16px; margin: 0 0 10px 0; }
    .group { margin: 10px 0 14px 0; }
    .group-title { font-size: 12px; letter-spacing: .08em; text-transform: uppercase; color:#666; margin: 10px 8px; }
    .item { display:block; padding: 8px 10px; border-radius: 10px; color:#111; text-decoration:none; }
    .item:hover { background:#f2f2f2; }
    .item-active { background:#111; color:#fff; }
    .meta { font-size: 12px; color:#666; margin-top: 10px; }
  </style>
</head>
<body>
<div class="shell">
  <aside class="nav">
    <div class="card">
      <div class="title">Interfacing</div>
      <div class="meta">Shell + screens (no SPA)</div>
    </div>

    {% for group, items in shell.nav.groupItem %}
      <div class="group">
        <div class="group-title">{{ group|e }}</div>
        <div>
          {% for it in items %}
            <a class="item {{ it.active ? 'item-active' : '' }}" href="/interfacing/{{ it.slug|e }}">{{ it.title|e }}</a>
          {% endfor %}
        </div>
      </div>
    {% endfor %}
  </aside>

  <main class="main">
    <div class="card">
      {% include 'interfacing/layout/screen.html.twig' with { screenSpec: screenSpec, layoutSpec: layoutSpec, context: context } %}
    </div>
  </main>
</div>
</body>
</html>
